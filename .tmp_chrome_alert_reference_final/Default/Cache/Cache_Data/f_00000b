, 0.7);\n\n  /* —— 侧栏(深色下使用更深一档,与深色背景更协调) —— */\n  --care-sidebar-bg: linear-gradient(180deg, #050d18 0%, #071827 50%, #0a1f1d 100%);\n  --care-sidebar-text: #cbd5e1;\n  --care-sidebar-text-active: #f0fdfa;\n  --care-sidebar-text-strong: #f8fafc;\n  --care-sidebar-muted: #64748b;\n  --care-sidebar-hover: rgba(45, 212, 191, 0.12);\n  --care-sidebar-active: linear-gradient(135deg, rgba(45, 212, 191, 0.7), rgba(56, 189, 248, 0.55));\n  --care-sidebar-footer-bg: rgba(125, 211, 252, 0.06);\n  --care-sidebar-divider: rgba(125, 211, 252, 0.12);\n  --care-shadow-color: rgba(0, 0, 0, 0.55);\n\n  /* —— Element Plus 主题覆盖（深色） —— */\n  --el-color-primary: #2dd4bf;\n  --el-color-primary-light-3: #5eead4;\n  --el-color-primary-light-5: #5eead4;\n  --el-color-primary-light-7: #99f6e4;\n  --el-color-primary-light-8: #ccfbf1;\n  --el-color-primary-light-9: #134e4a;\n  --el-color-primary-dark-2: #14b8a6;\n  --el-bg-color: #152338;\n  --el-bg-color-page: #0a1726;\n  --el-bg-color-overlay: #1e293b;\n  --el-text-color-primary: #e2e8f0;\n  --el-text-color-regular: #cbd5e1;\n  --el-text-color-secondary: #94a3b8;\n  --el-text-color-placeholder: #64748b;\n  --el-border-color: rgba(125, 211, 252, 0.18);\n  --el-border-color-light: rgba(125, 211, 252, 0.12);\n  --el-border-color-lighter: rgba(125, 211, 252, 0.06);\n  --el-fill-color-blank: #152338;\n  --el-fill-color-light: rgba(125, 211, 252, 0.06);\n  --el-fill-color-lighter: rgba(125, 211, 252, 0.03);\n  --el-fill-color: rgba(125, 211, 252, 0.1);\n  --el-mask-color: rgba(0, 0, 0, 0.7);\n}\n\n/* ==================== 基础 ==================== */\n* {\n  box-sizing: border-box;\n}\n\nhtml,\nbody,\n#app {\n  height: 100%;\n}\n\nbody {\n  margin: 0;\n  font-size: 16px;\n  line-height: 1.55;\n  color: var(--care-text);\n  background: var(--care-app-bg);\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',\n    'Microsoft YaHei', Roboto, Oxygen, Ubuntu, sans-serif;\n  transition: background-color 0.35s ease, color 0.35s ease;\n}\n\na {\n  color: var(--care-link);\n  text-decoration: none;\n}\n\nbutton,\n.el-button,\n.el-menu-item,\n.el-pagination button {\n  min-height: 44px;\n  font-size: 16px;\n}\n\na:focus-visible,\nbutton:focus-visible,\ninput:focus-visible,\nselect:focus-visible,\n.el-button:focus-visible,\n.el-menu-item:focus-visible {\n  outline: 3px solid rgba(56, 189, 248, 0.45);\n  outline-offset: 2px;\n}\n\n/* ==================== 通用容器 ==================== */\n.care-page-shell {\n  min-height: calc(100vh - 84px);\n  margin: -20px;\n  padding: 24px;\n  font-size: 16px;\n  background: var(--care-page-gradient);\n  color: var(--care-text);\n  transition: background 0.35s ease, color 0.35s ease;\n}\n\n.el-input__inner,\n.el-select__selected-item,\n.el-table,\n.el-pagination,\n.el-tag,\n.el-form-item__label {\n  font-size: 15px;\n}\n\n.care-page-shell small,\n.care-page-shell [class*='meta'],\n.care-page-shell [class*='hint'],\n.care-page-shell [class*='subtitle'],\n.care-page-shell [class*='caption'],\n.care-page-shell [class*='detail'] {\n  font-size: 14px !important;\n}\n\n.care-glass-card {\n  border: 1px solid var(--care-border);\n  border-radius: var(--care-radius-lg);\n  background: var(--care-surface);\n  color: var(--care-text);\n  box-shadow: var(--care-shadow);\n  backdrop-filter: blur(16px);\n  transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease,\n    color 0.35s ease;\n}\n\n.care-kicker {\n  color: var(--care-primary-strong);\n  font-size: 12px;\n  font-weight: 800;\n  letter-spacing: 0.16em;\n  text-transform: uppercase;\n}\n\n[data-theme='dark'] .care-kicker {\n  color: var(--care-primary-strong);\n}\n\n/* ==================== Element Plus 兜底 ==================== */\n[data-theme='dark'] .el-card,\n[data-theme='dark'] .el-table,\n[data-theme='dark'] .el-input__wrapper,\n[data-theme='dark'] .el-textarea__inner,\n[data-theme='dark'] .el-select__wrapper,\n[data-theme='dark'] .el-date-editor.el-input,\n[data-theme='dark'] .el-pagination {\n  background-color: var(--el-fill-color-blank);\n  color: var(--el-text-color-primary);\n  border-color: var(--el-border-color);\n}\n\n[data-theme='dark'] .el-table th,\n[data-theme='dark'] .el-table tr {\n  background-color: var(--el-fill-color-blank) !important;\n  color: var(--el-text-color-primary) !important;\n}\n\n[data-theme='dark'] .el-table--striped .el-table__body tr.el-table__row--striped td {\n  background-color: rgba(125, 211, 252, 0.04) !important;\n}\n\n[data-theme='dark'] .el-table td,\n[data-theme='dark'] .el-table th.is-leaf {\n  border-bottom-color: var(--el-border-color-lighter) !important;\n}\n\n[data-theme='dark'] .el-table--enable-row-hover .el-table__body tr:hover > td {\n  background-color: rgba(125, 211, 252, 0.08) !important;\n}\n\n[data-theme='dark'] .el-empty__description p {\n  color: var(--el-text-color-secondary);\n}\n\n[data-theme='dark'] .el-pagination .btn-prev,\n[data-theme='dark'] .el-pagination .btn-next,\n[data-theme='dark'] .el-pagination .el-pager li {\n  background-color: transparent;\n  color: var(--el-text-color-regular);\n}\n\n[data-theme='dark'] .el-pagination .el-pager li.is-active {\n  color: var(--el-color-primary);\n}\n\n[data-theme='dark'] .el-pagination__sizes .el-select .el-select__wrapper,\n[data-theme='dark'] .el-pagination__jump .el-input__wrapper {\n  background-color: var(--el-fill-color-blank);\n}\n\n[data-theme='dark'] .el-tag {\n  border-color: var(--el-border-color);\n}\n\n/* ==================== 浅色侧栏图标 ==================== */\n/* manage.vue 里的 .menu-icon 在浅色下要去掉 invert 滤镜，否则图标会变白看不见 */\n[data-theme='light'] .menu-icon {\n  filter: none;\n  opacity: 0.7;\n}\n\n/* ==================== 滚动条 ==================== */\n::-webkit-scrollbar {\n  width: 10px;\n  height: 10px;\n}\n::-webkit-scrollbar-track {\n  background: transparent;\n}\n::-webkit-scrollbar-thumb {\n  background: var(--care-border);\n  border-radius: 6px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: var(--care-primary-border);\n}\n\n::selection {\n  color: #ffffff;\n  background: var(--care-primary);\n}\n\n.el-input__wrapper.is-focus,\n.el-textarea__inner:focus,\n.el-select__wrapper.is-focused {\n  border-color: var(--care-primary) !important;\n  box-shadow: 0 0 0 3px rgba(17, 110, 138, 0.12) !important;\n}\n\n/* ==================== 医疗浅色统一风格覆盖 ====================\n   产品定位调整为医疗/养老护理监护屏：固定浅色、低噪声、高可读。\n   同时覆盖旧的 dark token，避免浏览器缓存历史主题导致页面变暗。\n*/\n:root,\n[data-theme='light'],\n[data-theme='dark'] {\n  color-scheme: light;\n  --care-bg: #eef8f7;\n  --care-bg-deep: #dcefed;\n  --care-app-bg: #f6fbfb;\n  --care-page-gradient:\n    radial-gradient(circle at 10% 8%, rgba(26, 188, 156, 0.14), transparent 34%),\n    radial-gradient(circle at 86% 10%, rgba(96, 165, 250, 0.14), transparent 34%),\n    linear-gradient(135deg, #f7fbfb 0%, #eef8f7 58%, #f4f8ff 100%);\n  --care-surface: #ffffff;\n  --care-surface-strong: #ffffff;\n  --care-surface-muted: #f3f9f9;\n  --care-surface-glass: rgba(255, 255, 255, 0.88);\n  --care-border: #d7e7ea;\n  --care-border-soft: #e5eff1;\n  --care-text: #274155;\n  --care-text-strong: #0f2537;\n  --care-muted: #64798a;\n  --care-muted-strong: #425b70;\n  --care-primary: #18b79f;\n  --care-primary-strong: #0f8f83;\n  --care-primary-soft: rgba(24, 183, 159, 0.14);\n  --care-primary-border: rgba(24, 183, 159, 0.34);\n  --care-accent: #2b8ee8;\n  --care-accent-soft: rgba(43, 142, 232, 0.14);\n  --care-success: #18a058;\n  --care-warning: #f59e0b;\n  --care-danger: #ef4444;\n  --care-danger-soft: rgba(239, 68, 68, 0.12);\n  --care-text-on-primary: #ffffff;\n  --care-shadow-soft: 0 10px 24px rgba(31, 78, 101, 0.08);\n  --care-shadow: 0 18px 48px rgba(31, 78, 101, 0.12);\n  --care-sidebar-bg: rgba(255, 255, 255, 0.92);\n  --care-sidebar-border: #dbe9ec;\n  --care-sidebar-text: #516b7d;\n  --care-sidebar-text-active: #0f766e;\n  --care-sidebar-active-bg: rgba(24, 183, 159, 0.12);\n\n  --el-color-primary: #18b79f;\n  --el-color-primary-light-3: #50cdbd;\n  --el-color-primary-light-5: #8be0d5;\n  --el-color-primary-light-7: #c8f1ec;\n  --el-color-primary-light-9: #edfafa;\n  --el-color-primary-dark-2: #0f8f83;\n  --el-bg-color: #ffffff;\n  --el-bg-color-page: #f6fbfb;\n  --el-bg-color-overlay: #ffffff;\n  --el-fill-color-blank: #ffffff;\n  --el-fill-color-light: #f5fafb;\n  --el-text-color-primary: #0f2537;\n  --el-text-color-regular: #274155;\n  --el-text-color-secondary: #64798a;\n  --el-border-color: #d7e7ea;\n  --el-border-color-light: #e1edf0;\n  --el-border-color-lighter: #edf4f5;\n}\n\nhtml.dark,\n[data-theme='dark'] {\n  color-scheme: light;\n}\n\nbody {\n  background: var(--care-app-bg) !important;\n}\n\n.care-page-shell {\n  background: var(--care-page-gradient);\n}\n\n.care-glass-card,\n.el-card,\n.el-dialog,\n.el-popover.el-popper {\n  background-color: rgba(255, 255, 255, 0.94) !important;\n  border-color: var(--care-border-soft) !important;\n  color: var(--care-text);\n}\n\n.el-table,\n.el-table th,\n.el-table tr,\n.el-input__wrapper,\n.el-textarea__inner,\n.el-select__wrapper,\n.el-date-editor.el-input,\n.el-pagination {\n  background-color: #ffffff !important;\n}\n\n.menu-icon {\n  filter: none !important;\n  opacity: 0.74;\n}\n\n/* ==================== 严肃医疗看护界面覆盖 ====================\n   目标：更接近医疗/养老护理工作台，而不是科技展板。\n   视觉原则：浅灰蓝底、白色内容区、清晰分隔线、低阴影、低圆角、风险色只用于告警。\n*/\n:root,\n[data-theme='light'],\n[data-theme='dark'] {\n  --clinical-bg: #f3f6f8;\n  --clinical-panel: #ffffff;\n  --clinical-panel-muted: #f8fafc;\n  --clinical-border: #d8e1e8;\n  --clinical-border-strong: #c5d1da;\n  --clinical-heading: #102a43;\n  --clinical-text: #263f53;\n  --clinical-muted: #66798a;\n  --clinical-primary: #116e8a;\n  --clinical-primary-soft: #e7f1f5;\n  --clinical-success: #188758;\n  --clinical-warning: #b7791f;\n  --clinical-danger: #c53030;\n\n  --care-bg: var(--clinical-bg);\n  --care-app-bg: var(--clinical-bg);\n  --care-page-gradient: linear-gradient(180deg, #f7f9fb 0%, #f2f6f8 100%);\n  --care-surface: var(--clinical-panel);\n  --care-surface-strong: var(--clinical-panel);\n  --care-surface-muted: var(--clinical-panel-muted);\n  --care-surface-soft: #ffffff;\n  --care-surface-2: #ffffff;\n  --care-border: var(--clinical-border);\n  --care-border-soft: #e2e8ee;\n  --care-divider: var(--clinical-border);\n  --care-text: var(--clinical-text);\n  --care-text-strong: var(--clinical-heading);\n  --care-muted: var(--clinical-muted);\n  --care-muted-strong: #4f6274;\n  --care-primary: var(--clinical-primary);\n  --care-primary-strong: #0d5d75;\n  --care-primary-soft: var(--clinical-primary-soft);\n  --care-primary-border: #bad3dd;\n  --care-accent: #2f80a5;\n  --care-accent-soft: #e8f2f6;\n  --care-success: var(--clinical-success);\n  --care-success-soft: #e8f5ef;\n  --care-warning: var(--clinical-warning);\n  --care-warning-soft: #fff7e6;\n  --care-danger: var(--clinical-danger);\n  --care-danger-soft: #fff1f1;\n  --care-shadow-soft: 0 2px 8px rgba(16, 42, 67, 0.05);\n  --care-shadow: 0 4px 16px rgba(16, 42, 67, 0.07);\n  --care-shadow-card: 0 2px 10px rgba(16, 42, 67, 0.06);\n  --care-shadow-strong: 0 8px 24px rgba(16, 42, 67, 0.1);\n  --care-radius-lg: 14px;\n  --care-radius-md: 10px;\n  --care-radius-sm: 8px;\n  --care-sidebar-bg: #ffffff;\n  --care-sidebar-text: #43596b;\n  --care-sidebar-text-active: #0d5d75;\n  --care-sidebar-text-strong: #102a43;\n  --care-sidebar-muted: #748697;\n  --care-sidebar-hover: #f2f7f9;\n  --care-sidebar-active: #e7f1f5;\n  --care-sidebar-footer-bg: #f8fafc;\n  --care-sidebar-divider: #d8e1e8;\n\n  --el-color-primary: var(--clinical-primary);\n  --el-color-primary-light-3: #4d92a9;\n  --el-color-primary-light-5: #87b6c7;\n  --el-color-primary-light-7: #bad3dd;\n  --el-color-primary-light-9: #edf5f8;\n  --el-color-primary-dark-2: #0d5d75;\n  --el-bg-color-page: var(--clinical-bg);\n  --el-text-color-primary: var(--clinical-heading);\n  --el-text-color-regular: var(--clinical-text);\n  --el-text-color-secondary: var(--clinical-muted);\n  --el-border-color: var(--clinical-border);\n  --el-border-color-light: #e2e8ee;\n  --el-border-color-lighter: #edf1f4;\n}\n\nbody {\n  background: var(--clinical-bg) !important;\n  color: var(--clinical-text) !important;\n}\n\n.care-page-shell {\n  background: var(--care-page-gradient) !important;\n}\n\n.care-glass-card,\n.el-card,\n.el-dialog,\n.el-popover.el-popper {\n  border: 1px solid var(--clinical-border) !important;\n  border-radius: var(--care-radius-lg) !important;\n  background: var(--clinical-panel) !important;\n  box-shadow: var(--care-shadow-soft) !important;\n  backdrop-filter: none !important;\n}\n\n.el-button,\n.el-input__wrapper,\n.el-textarea__inner,\n.el-select__wrapper,\n.el-input-number,\n.el-tag {\n  border-radius: 8px !important;\n}\n\n.el-button {\n  box-shadow: none !important;\n  font-weight: 700 !important;\n}\n\n.el-button--primary {\n  background: var(--clinical-primary) !important;\n  border-color: var(--clinical-primary) !important;\n}\n\n/* 主框架：工作台感，减少渐变和悬浮感 */\n.layout-container,\n.main-content {\n  background: var(--clinical-bg) !important;\n}\n\n.sidebar {\n  background: #ffffff !important;\n  border-right: 1px solid var(--clinical-border) !important;\n  box-shadow: none !important;\n}\n\n.sidebar-header {\n  border-bottom-color: var(--clinical-border) !important;\n}\n\n.brand-copy strong,\n.top-bar strong,\nh1,\nh2,\nh3 {\n  color: var(--clinical-heading) !important;\n}\n\n.el-menu-item {\n  margin: 4px 12px !important;\n  border-radius: 8px !important;\n}\n\n.el-menu-item.is-active {\n  background: var(--clinical-primary-soft) !important;\n  color: var(--clinical-primary) !important;\n  box-shadow: none !important;\n  border-left: 3px solid var(--clinical-primary);\n}\n\n.top-bar {\n  background: #ffffff !important;\n  border-bottom: 1px solid var(--clinical-border) !important;\n  box-shadow: none !important;\n}\n\n.content-area {\n  background: transparent !important;\n}\n\n/* 登录/注册：从营销封面改成护理系统入口 */\n.auth-page {\n  background: var(--clinical-bg) !important;\n}\n\n.auth-intr