const __vite__css = "/* =====================================================================\n   HRRR Radar Monitor - 全局主题\n   通过 :root 与 [data-theme=\"dark\"] / [data-theme=\"light\"] 提供完整 token\n   业务页面/Element Plus 均通过 CSS 变量响应切换\n   ===================================================================== */\n\n:root,\n[data-theme='light'] {\n  color-scheme: light;\n\n  /* —— 画布 —— */\n  --care-bg: #edf7f6;\n  --care-bg-deep: #071827;\n  --care-app-bg: #f5fbfa;\n  --care-page-gradient:\n    radial-gradient(circle at 5% 5%, rgba(22, 183, 169, 0.18), transparent 34%),\n    radial-gradient(circle at 94% 10%, rgba(56, 189, 248, 0.16), transparent 30%),\n    linear-gradient(135deg, #f5fbfa 0%, #edf7f6 48%, #e8f5ff 100%);\n\n  /* —— 表面 —— */\n  --care-surface: rgba(255, 255, 255, 0.88);\n  --care-surface-strong: #ffffff;\n  --care-surface-soft: rgba(255, 255, 255, 0.66);\n  --care-surface-2: rgba(255, 255, 255, 0.78);\n  --care-surface-dark: rgba(9, 24, 45, 0.82);\n  --care-surface-muted: rgba(100, 116, 139, 0.08);\n  --care-surface-inverse: #0f1f2e;\n\n  /* —— 主题色 —— */\n  --care-primary: #16b7a9;\n  --care-primary-strong: #0f8f85;\n  --care-primary-soft: rgba(22, 183, 169, 0.1);\n  --care-primary-border: rgba(22, 183, 169, 0.22);\n  --care-accent: #38bdf8;\n  --care-accent-soft: rgba(56, 189, 248, 0.12);\n  --care-success: #16a34a;\n  --care-success-soft: rgba(22, 163, 74, 0.1);\n  --care-warning: #f59e0b;\n  --care-warning-soft: rgba(245, 158, 11, 0.12);\n  --care-danger: #ef4444;\n  --care-danger-soft: rgba(239, 68, 68, 0.1);\n\n  /* —— 文字 —— */\n  --care-text: #102333;\n  --care-text-strong: #0a1726;\n  --care-text-inverse: #ffffff;\n  --care-text-on-primary: #ffffff;\n  --care-muted: #64748b;\n  --care-muted-strong: #41576b;\n  --care-link: #0369a1;\n\n  /* —— 边线/分割线 —— */\n  --care-border: rgba(15, 143, 133, 0.16);\n  --care-border-soft: rgba(15, 143, 133, 0.12);\n  --care-divider: rgba(15, 59, 72, 0.12);\n  --care-divider-strong: rgba(15, 59, 72, 0.2);\n  --care-grid-line: rgba(100, 116, 139, 0.14);\n  --care-grid-line-soft: rgba(100, 116, 139, 0.08);\n\n  /* —— 阴影 —— */\n  --care-shadow: 0 18px 55px rgba(15, 59, 72, 0.12);\n  --care-shadow-soft: 0 10px 30px rgba(15, 59, 72, 0.09);\n  --care-shadow-card: 0 4px 20px rgba(15, 59, 72, 0.08);\n  --care-shadow-strong: 0 24px 70px rgba(15, 59, 72, 0.18);\n\n  /* —— 圆角 —— */\n  --care-radius-lg: 24px;\n  --care-radius-md: 16px;\n  --care-radius-sm: 12px;\n  --care-radius-pill: 999px;\n\n  /* —— 侧栏(浅色下与画布同色系) —— */\n  --care-sidebar-bg: linear-gradient(180deg, #ffffff 0%, #f0faf8 52%, #e6f5ff 100%);\n  --care-sidebar-text: #102333;\n  --care-sidebar-text-active: #0a1726;\n  --care-sidebar-text-strong: #0a1726;\n  --care-sidebar-muted: #64748b;\n  --care-sidebar-hover: rgba(22, 183, 169, 0.1);\n  --care-sidebar-active: linear-gradient(135deg, rgba(22, 183, 169, 0.18), rgba(56, 189, 248, 0.14));\n  --care-sidebar-footer-bg: rgba(15, 59, 72, 0.04);\n  --care-sidebar-divider: rgba(15, 59, 72, 0.1);\n  --care-shadow-color: rgba(7, 24, 39, 0.1);\n\n  /* —— Element Plus 主题覆盖 —— */\n  --el-color-primary: #16b7a9;\n  --el-color-primary-light-3: #4ec5b9;\n  --el-color-primary-light-5: #80d3c9;\n  --el-color-primary-light-7: #b3e2dc;\n  --el-color-primary-light-8: #cce9e5;\n  --el-color-primary-light-9: #e6f4f2;\n  --el-color-primary-dark-2: #0f8f85;\n  --el-bg-color: #ffffff;\n  --el-bg-color-page: #f5fbfa;\n  --el-bg-color-overlay: #ffffff;\n  --el-text-color-primary: #102333;\n  --el-text-color-regular: #334155;\n  --el-text-color-secondary: #64748b;\n  --el-text-color-placeholder: #94a3b8;\n  --el-border-color: rgba(15, 143, 133, 0.16);\n  --el-border-color-light: rgba(15, 143, 133, 0.12);\n  --el-border-color-lighter: rgba(15, 143, 133, 0.08);\n  --el-fill-color-blank: #ffffff;\n  --el-fill-color-light: rgba(15, 143, 133, 0.04);\n  --el-fill-color-lighter: rgba(15, 143, 133, 0.02);\n  --el-fill-color: rgba(15, 143, 133, 0.08);\n  --el-mask-color: rgba(15, 23, 42, 0.45);\n}\n\n[data-theme