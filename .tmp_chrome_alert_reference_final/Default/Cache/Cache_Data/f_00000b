tion .bed-card.warning {\n  border-color: #d6a54d !important;\n  background: #fffaf0 !important;\n}\n\n.bed-card.critical,\n.ward-screen .bed-card.critical,\n.nurse-station .bed-card.critical {\n  border-color: #d45b5b !important;\n  background: #fff6f6 !important;\n}\n\n.bed-card.offline,\n.ward-screen .bed-card.offline,\n.nurse-station .bed-card.offline {\n  border-color: #cbd5df !important;\n  background: #f7f9fb !important;\n  opacity: 0.78 !important;\n}\n\n.risk-badge,\n.status-badge,\n.device-row span,\n.sim-badge,\n.alert-list span {\n  border-radius: 6px !important;\n  box-shadow: none !important;\n}\n\n.device-row span.on {\n  color: var(--clinical-success) !important;\n  background: #e8f5ef !important;\n}\n\n.ward-screen {\n  background: var(--clinical-bg) !important;\n}\n\n.screen-header h1 {\n  font-size: clamp(30px, 3vw, 42px) !important;\n}\n\n.summary-strip article strong,\n.hero-stats strong {\n  font-size: 28px !important;\n}\n\n.breath-indicator {\n  animation-duration: 4s !important;\n  opacity: 0.45 !important;\n}\n\n.bed-card.critical,\n.summary-strip .pulse {\n  animation: none !important;\n}\n\n/* 预警中心：更像流程处置台，不做展示型发光 */\n.emergency-workspace {\n  border-radius: 10px !important;\n  box-shadow: var(--care-shadow) !important;\n}\n\n.sos-mark {\n  border-radius: 10px !important;\n  box-shadow: none !important;\n  background: var(--clinical-danger) !important;\n}\n\n.matrix-item,\n.action-item,\n.empty-actions {\n  border-radius: 10px !important;\n  background: #ffffff !important;\n}\n\n.matrix-icon {\n  border-radius: 8px !important;\n  background: var(--clinical-panel-muted) !important;\n}\n\n/* =====================================================================\n   Silver Shield UI iteration\n   参考图视觉提炼：高明度冷灰背景、品牌蓝、深蓝文字、白色软卡片、\n   大留白、细边框、弱阴影、少量红色仅用于紧急风险。\n   ===================================================================== */\n:root,\n[data-theme='light'],\n[data-theme='dark'] {\n  color-scheme: light !important;\n\n  --shield-brand: #325bf2;\n  --shield-brand-hover: #2649d9;\n  --shield-primary: #222e61;\n  --shield-secondary: #7982a6;\n  --shield-secondary-soft: #c8cfde;\n  --shield-bg: #f3f6fb;\n  --shield-bg-2: #eef2f8;\n  --shield-card: #ffffff;\n  --shield-card-soft: #f8faff;\n  --shield-line: #dfe5f0;\n  --shield-line-strong: #c7d0df;\n  --shield-text: #26324f;\n  --shield-muted: #6c768f;\n  --shield-danger: #e23744;\n  --shield-danger-soft: #fff0f2;\n  --shield-warning: #ee9b2d;\n  --shield-warning-soft: #fff7e8;\n  --shield-success: #27b36a;\n  --shield-success-soft: #eaf8f1;\n  --shield-radius-xl: 24px;\n  --shield-radius-lg: 18px;\n  --shield-radius-md: 14px;\n  --shield-radius-sm: 10px;\n  --shield-shadow-card: 0 12px 32px rgba(34, 46, 97, 0.08);\n  --shield-shadow-soft: 0 6px 18px rgba(34, 46, 97, 0.06);\n  --shield-shadow-hover: 0 18px 42px rgba(34, 46, 97, 0.12);\n\n  --care-bg: var(--shield-bg);\n  --care-app-bg: var(--shield-bg);\n  --care-page-gradient:\n    linear-gradient(105deg, rgba(255,255,255,0.58) 0 22%, transparent 22% 100%),\n    radial-gradient(circle at 6% 90%, rgba(50, 91, 242, 0.08), transparent 28%),\n    linear-gradient(180deg, #f8faff 0%, #eef2f8 100%);\n  --care-surface: var(--shield-card);\n  --care-surface-strong: var(--shield-card);\n  --care-surface-soft: rgba(255,255,255,0.86);\n  --care-surface-2: var(--shield-card-soft);\n  --care-surface-muted: #f5f7fc;\n  --care-border: var(--shield-line);\n  --care-border-soft: #e8edf5;\n  --care-divider: var(--shield-line);\n  --care-text: var(--shield-text);\n  --care-text-strong: var(--shield-primary);\n  --care-muted: var(--shield-muted);\n  --care-muted-strong: #4d5877;\n  --care-primary: var(--shield-brand);\n  --care-primary-strong: var(--shield-brand);\n  --care-primary-soft: rgba(50, 91, 242, 0.1);\n  --care-primary-border: rgba(50, 91, 242, 0.26);\n  --care-accent: #45b4ff;\n  --care-accent-soft: rgba(69, 180, 255, 0.11);\n  --care-success: var(--shield-success);\n  --care-success-soft: var(--shield-success-soft);\n  --care-warning: var(--shield-warning);\n  --care-warning-soft: var(--shield-warning-soft);\n  --care-danger: var(--shield-danger);\n  --care-danger-soft: var(--shield-danger-soft);\n  --care-shadow: var(--shield-shadow-card);\n  --care-shadow-soft: var(--shield-shadow-soft);\n  --care-shadow-card: var(--shield-shadow-soft);\n  --care-shadow-strong: var(--shield-shadow-hover);\n  --care-radius-lg: var(--shield-radius-xl);\n  --care-radius-md: var(--shield-radius-lg);\n  --care-radius-sm: var(--shield-radius-md);\n  --care-sidebar-bg: rgba(255,255,255,0.94);\n  --care-sidebar-text: #56617c;\n  --care-sidebar-text-active: var(--shield-brand);\n  --care-sidebar-text-strong: var(--shield-primary);\n  --care-sidebar-muted: var(--shield-secondary);\n  --care-sidebar-hover: rgba(50, 91, 242, 0.06);\n  --care-sidebar-active: rgba(50, 91, 242, 0.12);\n  --care-sidebar-footer-bg: #f7f9fd;\n  --care-sidebar-divider: var(--shield-line);\n\n  --el-color-primary: var(--shield-brand);\n  --el-color-primary-dark-2: var(--shield-brand-hover);\n  --el-color-primary-light-3: #5d7afa;\n  --el-color-primary-light-5: #8ba0fb;\n  --el-color-primary-light-7: #bdc8fd;\n  --el-color-primary-light-9: #eef2ff;\n  --el-bg-color: var(--shield-card);\n  --el-bg-color-page: var(--shield-bg);\n  --el-bg-color-overlay: var(--shield-card);\n  --el-fill-color-blank: var(--shield-card);\n  --el-fill-color-light: #f6f8fd;\n  --el-fill-color-lighter: #fafbff;\n  --el-text-color-primary: var(--shield-primary);\n  --el-text-color-regular: var(--shield-text);\n  --el-text-color-secondary: var(--shield-muted);\n  --el-border-color: var(--shield-line);\n  --el-border-color-light: #e8edf5;\n  --el-border-color-lighter: #f0f3f8;\n}\n\nbody {\n  font-size: 15px;\n  line-height: 1.68;\n  color: var(--shield-text) !important;\n  background:\n    linear-gradient(115deg, rgba(255,255,255,0.74) 0 18%, transparent 18% 100%),\n    var(--shield-bg) !important;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'SF Pro Display',\n    Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;\n  letter-spacing: 0.005em;\n}\n\nh1,\nh2,\nh3,\n.brand-copy strong,\n.top-bar strong {\n  color: var(--shield-primary) !important;\n  letter-spacing: -0.025em;\n}\n\np,\n.subtitle,\n.top-bar-subtitle {\n  color: var(--shield-muted) !important;\n}\n\n.care-page-shell {\n  min-height: calc(100vh - 84px);\n  padding: 34px !important;\n  background: var(--care-page-gradient) !important;\n}\n\n.care-glass-card,\n.el-card,\n.el-dialog,\n.el-popover.el-popper,\n.auth-card,\n.auth-intro {\n  border: 1px solid rgba(199, 208, 223, 0.78) !important;\n  border-radius: var(--shield-radius-xl) !important;\n  background: rgba(255, 255, 255, 0.94) !important;\n  box-shadow: var(--shield-shadow-card) !important;\n  backdrop-filter: blur(10px);\n}\n\n.care-glass-card:hover,\n.el-card:hover {\n  box-shadow: var(--shield-shadow-hover) !important;\n}\n\n.layout-container,\n.main-content,\n.content-area {\n  background: transparent !important;\n}\n\n.sidebar {\n  width: 232px !important;\n  background:\n    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,249,253,0.96)) !important;\n  border-right: 1px solid var(--shield-line) !important;\n  box-shadow: 8px 0 28px rgba(34, 46, 97, 0.04) !important;\n}\n\n.sidebar-header {\n  min-height: 92px;\n  border-bottom: 1px solid var(--shield-line) !important;\n}\n\n.logo {\n  filter: drop-shadow(0 6px 12px rgba(50, 91, 242, 0.16));\n}\n\n.el-menu-item {\n  min-height: 46px !important;\n  margin: 6px 14px !important;\n  border-radius: 14px !important;\n  color: #56617c !important;\n  font-size: 14px !important;\n  font-weight: 700 !important;\n  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;\n}\n\n.el-menu-item:hover {\n  background: rgba(50, 91, 242, 0.06) !important;\n  color: var(--shield-primary) !important;\n  transform: translateX(2px);\n}\n\n.el-menu-item.is-active {\n  background: var(--shield-brand) !important;\n  color